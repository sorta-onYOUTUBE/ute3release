local function log(msg, success)
    local l = Instance.new("TextLabel", Console)
    l.Size = UDim2.new(1,0,0,16); l.BackgroundTransparency = 1
    l.Text = msg:lower() .. " ::"
    l.TextColor3 = success and Color3.new(0.6, 0.6, 0.6) or Color3.fromRGB(150, 50, 50)
    l.Font = "Code"; l.TextSize = 11; l.TextXAlignment = "Right"
end

local function addCmd(n, cb)
    local slug = n:gsub("%s+", ""):lower()
    _G.CommandRegistry[slug] = {callback = cb, originalName = n}
    local t = Instance.new("TextButton", CmdPage)
    t.Name = slug
    t.Text = n:lower()
    t.Font = "Code"
    t.BorderSizePixel = 1
    t.BorderColor3 = Color3.fromRGB(45, 45, 45)
    t.TextWrapped = true
    t.TextSize = 10
    
    local function updateUI()
        t.BackgroundColor3 = _G.States[n] and Color3.fromRGB(60, 60, 60) or Color3.fromRGB(15, 15, 15)
        t.BackgroundTransparency = 0.5
        t.TextColor3 = _G.States[n] and Color3.new(1, 1, 1) or Color3.new(0.5, 0.5, 0.5)
    end
    
    t.MouseButton1Click:Connect(function()
        _G.States[n] = not _G.States[n]
        local s, e = pcall(cb)
        updateUI(); log(n, s)
    end)
    updateUI()
end

-- [[ TERMINAL LOGIC ]] --
TerminalInput.FocusLost:Connect(function(enter)
    if enter then
        local raw = TerminalInput.Text:lower()
        local args = raw:split(" ")
        local cmdKey = args[1]
        if _G.CommandRegistry[cmdKey] then
            local cmd = _G.CommandRegistry[cmdKey]
            _G.States[cmd.originalName] = not _G.States[cmd.originalName]
            local s, e = pcall(cmd.callback)
            log("toggle: " .. cmd.originalName, s)
            if CmdPage:FindFirstChild(cmdKey) then
                local btn = CmdPage[cmdKey]
                btn.BackgroundColor3 = _G.States[cmd.originalName] and Color3.fromRGB(60, 60, 60) or Color3.fromRGB(15, 15, 15)
            end
        elseif cmdKey == "target" and args[2] then
            _G.target = args[2]
            log("target -> " .. _G.target, true)
        else
            local s, e = pcall(function() loadstring(TerminalInput.Text)() end)
            log("lua_run", s)
        end
        TerminalInput.Text = ""
    end
end)

